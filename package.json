{
  "name": "bloomly",
  "version": "2.0.0",
  "description": "Bloomly - Teen mental health awareness and support platform",
  "main": "index.html",
  "scripts": {
    "start": "npx serve . -p 3000",
    "dev": "npx serve . -p 3000",
    "build:admin-editor": "esbuild admin/editor-src/index.js --bundle --minify --format=iife --global-name=BloomlyCMSEditorBundle --outfile=admin/blog-cms-editor.js --target=es2020",
    "build": "npm run build:admin-editor && node scripts/generate-config.js && node scripts/generate-blog-routes.js && node scripts/generate-blog-manifest.js",
    "set-admin-secrets": "node scripts/set-supabase-admin-secrets.js"
  },
  "keywords": [
    "wellness",
    "mental-health",
    "teen-mental-health",
    "bloomly"
  ],
  "author": "Bloomly",
  "license": "MIT",
  "dependencies": {
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-table-cell": "^3.27.1",
    "@tiptap/extension-table-header": "^3.27.1",
    "@tiptap/extension-table-row": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
