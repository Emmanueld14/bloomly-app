{
  "outputDirectory": ".",
  "functions": {
    "api/github-auth.js": {
      "maxDuration": 10
    },
    "api/mpesa/stkpush.js": {
      "maxDuration": 10
    },
    "api/mpesa/status.js": {
      "maxDuration": 10
    },
    "api/stripe/checkout.js": {
      "maxDuration": 10
    },
    "api/stripe/confirm.js": {
      "maxDuration": 10
    },
    "api/auth/callback/github.js": {
      "maxDuration": 10
    },
    "api/test.js": {
      "maxDuration": 10
    }
  },
  "redirects": [
    {
      "source": "/team",
      "destination": "/about.html",
      "permanent": true
    },
    {
      "source": "/team/",
      "destination": "/about.html",
      "permanent": true
    },
    {
      "source": "/team/:slug",
      "destination": "/members/?id=:slug",
      "permanent": true
    },
    {
      "source": "/team/:slug/",
      "destination": "/members/?id=:slug",
      "permanent": true
    },
    {
      "source": "/people",
      "destination": "/members/",
      "permanent": true
    },
    {
      "source": "/people/",
      "destination": "/members/",
      "permanent": true
    },
    {
      "source": "/profile/:slug",
      "destination": "/members/?id=:slug",
      "permanent": true
    },
    {
      "source": "/profile/:slug/",
      "destination": "/members/?id=:slug",
      "permanent": true
    },
    {
      "source": "/people/:slug",
      "destination": "/members/?id=:slug",
      "permanent": true
    },
    {
      "source": "/people/:slug/",
      "destination": "/members/?id=:slug",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/blog",
      "destination": "/blog/index.html"
    },
    {
      "source": "/blog/",
      "destination": "/blog/index.html"
    },
    {
      "source": "/blog/index.html",
      "destination": "/blog/index.html"
    },
    {
      "source": "/blog/:slug",
      "destination": "/blog/:slug/"
    },
    {
      "source": "/about",
      "destination": "/about/"
    },
    {
      "source": "/about.html",
      "destination": "/about/"
    },
    {
      "source": "/blog-post",
      "destination": "/blog-post/index.html"
    },
    {
      "source": "/blog-post/",
      "destination": "/blog-post/index.html"
    },
    {
      "source": "/subscribe",
      "destination": "/subscribe/index.html"
    },
    {
      "source": "/subscribe/",
      "destination": "/subscribe/index.html"
    },
    {
      "source": "/terms",
      "destination": "/terms/index.html"
    },
    {
      "source": "/terms/",
      "destination": "/terms/index.html"
    },
    {
      "source": "/admin/login",
      "destination": "/admin/login/"
    },
    {
      "source": "/admin/login.html",
      "destination": "/admin/login/"
    },
    {
      "source": "/appointments",
      "destination": "/index.html"
    },
    {
      "source": "/appointments/",
      "destination": "/index.html"
    },
    {
      "source": "/appointments/:path*",
      "destination": "/index.html"
    }
  ]
}
