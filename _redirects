# Cloudflare Pages redirects
# Format: /from /to [status]

# Admin routing
/admin /admin/index.html 200
/admin/login /admin/login/ 301
/admin/login.html /admin/login/ 301

# Blog routing
/blog /blog/index.html 200
/blog/ /blog/index.html 200
/blog/index.html /blog/index.html 200
/blog/:slug /blog/:slug/ 301

# Legacy blog-post path (no slug)
/blog-post /blog-post/index.html 200
/blog-post/ /blog-post/index.html 200
/blog.html /blog/index.html 301
/blog-post.html /blog-post/index.html 301

# About page (directory index — works without rewrite engine)
/about /about/ 301
/about.html /about/ 301

# Subscribe page routing
/subscribe /subscribe/index.html 200
/subscribe/ /subscribe/index.html 200

# Terms routing
/terms /terms/index.html 200
/terms/ /terms/index.html 200

# Charla temporarily disabled — redirect home (code kept at /appointments/index.html)
/appointments /index.html 302
/appointments/ /index.html 302
/appointments/* /index.html 302

# Team profile routing - legacy routes
/team /about.html 301
/team/ /about.html 301
/team/* /members/?id=:splat 301

# Profile routing (legacy)
/profile /members/ 301
/profile/ /members/ 301
/profile/* /members/?id=:splat 301

# People profile routing (legacy)
/people /members/ 301
/people/ /members/ 301
/people/* /members/?id=:splat 301

