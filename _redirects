# Cloudflare Pages redirects
# Format: /from /to [status]

# Admin routing
/admin /admin/index.html 200

# Blog routing
/blog /blog/index.html 200
/blog/ /blog/index.html 200
/blog/* /blog-post.html?slug=:splat 200

# Legacy blog-post paths
/blog-post /blog 301
/blog-post/ /blog 301
/blog-post/* /blog/:splat 301
/blog.html /blog/index.html 301
/blog-post.html /blog 301

# Subscribe page routing
/subscribe /subscribe/index.html 200
/subscribe/ /subscribe/index.html 200

# Terms routing
/terms /terms/index.html 200
/terms/ /terms/index.html 200

# Appointments routing
/appointments /appointments/index.html 200
/appointments/ /appointments/index.html 200

# Team profile routing - legacy routes
/team /about.html 301
/team/ /about.html 301
/team/* /members/?id=:splat 301

# Profile routing (legacy)
/profile /members/ 301
/profile/ /members/ 301
/profile/* /members/?id=:splat 301

# People profile routing (legacy)
/people /members/ 301
/people/ /members/ 301
/people/* /members/?id=:splat 301

